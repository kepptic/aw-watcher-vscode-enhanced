{
    "name": "aw-watcher-vscode-enhanced",
    "displayName": "ActivityWatch VS Code Enhanced",
    "description": "Enhanced editor watcher for ActivityWatch — tracks files, terminals, git, debugging, and more.",
    "version": "1.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/kepptic/aw-watcher-vscode-enhanced"
    },
    "publisher": "kepptic",
    "author": "Kepptic (forked from ActivityWatch/aw-watcher-vscode)",
    "license": "MPL-2.0",
    "bugs": {
        "url": "https://github.com/kepptic/aw-watcher-vscode-enhanced/issues"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "multi-root ready",
        "activitywatch",
        "time-tracking",
        "terminal",
        "git"
    ],
    "icon": "media/logo/logo.png",
    "activationEvents": [
        "*"
    ],
    "extensionKind": [
        "ui"
    ],
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": true
        }
    },
    "main": "./out/src/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.reload",
                "title": "Reload ActivityWatch"
            },
            {
                "command": "aw-watcher-vscode.showMenu",
                "title": "ActivityWatch: Show Menu"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "ActivityWatch VS Code Enhanced",
            "properties": {
                "aw-watcher-vscode.maxHeartbeatsPerSec": {
                    "type": "number",
                    "default": 1,
                    "description": "Maximum heartbeats sent per second."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "test": "npm run compile",
        "vscode:prepublish": "npm run compile"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.75.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0",
        "typescript": "^5.4.0"
    },
    "dependencies": {
        "axios": "^1.7.0"
    }
}
